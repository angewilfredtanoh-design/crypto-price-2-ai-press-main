# ============================================================
# NEO CRYPTO DASH - Fichier d'exemple des variables d'environnement
# ============================================================
# 1. Copie ce fichier en .env
# 2. Remplis tes vraies valeurs
# 3. NE JAMAIS COMMITTER .env (déjà dans .gitignore)
# 4. Sur Hostinger : tu peux définir ces variables dans le panel ou via .htaccess / php.ini

# --- Clé Mistral AI (obligatoire) ---
# Va sur https://console.mistral.ai/ pour générer tes clés (Free Tier = 1 milliard tokens/mois par clé)
MISTRAL_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Configuration générale (optionnel) ---
APP_ENV=development
APP_DEBUG=true

# --- Base de données (si tu utilises SQLite pour l'instant, pas besoin) ---
# DB_FILE=crypto_cache.db

# --- Trading virtuel ---
INITIAL_CAPITAL=1000000

# --- Logs ---
LOG_LEVEL=info
