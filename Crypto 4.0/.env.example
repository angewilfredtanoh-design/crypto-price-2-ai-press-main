# ============================================================================
# FICHIER DE CONFIGURATION DES VARIABLES D'ENVIRONNEMENT
# Crypto 4.0 - NEO CRYPTO DASH
# ============================================================================
#
# INSTRUCTIONS:
# 1. Copiez ce fichier en .env (ne pas committer .env dans Git !)
# 2. Remplacez les valeurs placeholder par vos vraies clés API
# 3. Assurez-vous que le fichier .env n'est PAS versionné (.gitignore)
#
# SÉCURITÉ: Ne jamais committer de clés API dans le code source!
# ============================================================================

# ----------------------------------------------------------------------------
# CLÉS API MISTRAL
# ----------------------------------------------------------------------------
# Option 1: Une seule clé API
MISTRAL_API_KEY=votre_cle_api_mistral_ici

# Option 2: Plusieurs clés pour la rotation (séparées par des virgules)
# MISTRAL_API_KEYS=cle_1,cle_2,cle_3

# Option 3: Clés individuelles numérotées
# MISTRAL_API_KEY_1=premiere_cle
# MISTRAL_API_KEY_2=deuxieme_cle
# MISTRAL_API_KEY_3=troisieme_cle

# ----------------------------------------------------------------------------
# ENVIRONNEMENT
# ----------------------------------------------------------------------------
# Valeurs possibles: development, staging, production
APP_ENV=development

# ----------------------------------------------------------------------------
# BASE DE DONNÉES (optionnel - SQLite par défaut)
# ----------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=crypto_db
# DB_USER=root
# DB_PASSWORD=votre_mot_de_passe

# ----------------------------------------------------------------------------
# REDIS (optionnel - pour le cache avancé)
# ----------------------------------------------------------------------------
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ----------------------------------------------------------------------------
| # LOG LEVEL
# ----------------------------------------------------------------------------
# Valeurs: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# TRADING (optionnel - pour override des paramètres)
# ----------------------------------------------------------------------------
# INITIAL_CAPITAL=1000000
# MAX_POSITION_SIZE=50000
# STOP_LOSS_PERCENT=15
# TAKE_PROFIT_PERCENT=25
