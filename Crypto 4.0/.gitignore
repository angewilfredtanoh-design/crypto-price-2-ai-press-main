# =============================================================================
# .gitignore - Crypto 4.0 Project
# =============================================================================

# ------------------------------------------------------------------------------
# DÉPENDANCES & COMPOSER
# ------------------------------------------------------------------------------
/vendor/
/composer.lock

# ------------------------------------------------------------------------------
# FICHIERS DE BASE DE DONNÉES
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
/crypto_cache.db
/data/*.db

# ------------------------------------------------------------------------------
# LOGS & CACHE
# ------------------------------------------------------------------------------
/logs/
*.log
logs/app.log
logs/error.log
logs/api_usage.log
/cache/
!cache/.gitkeep

# ------------------------------------------------------------------------------
# VARIABLES D'ENVIRONNEMENT & SECRETS
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
config.local.php
config.override.php
!config.example.php

# ------------------------------------------------------------------------------
# CLÉS API & FICHIERS SENSIBLES
# ------------------------------------------------------------------------------
api_keys.txt
secrets/
keys/
*.key
*.pem

# ------------------------------------------------------------------------------
# EXPORTS & DONNÉES GÉNÉRÉES
# ------------------------------------------------------------------------------
/exports/
/data/*.csv
/data/*.json
!data/.gitkeep
reports/
backups/

# ------------------------------------------------------------------------------
# IDÉES DE DÉVELOPPEMENT & IDE
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# TESTS & COUVERTURE
# ------------------------------------------------------------------------------
/phpunit.xml
/tests/coverage/
/tests/_output/
.phpunit.result.cache

# ------------------------------------------------------------------------------
# BUILD & ARTIFACTS
# ------------------------------------------------------------------------------
/build/
/dist/
/artifacts/

# ------------------------------------------------------------------------------
# DOCUMENTATION GÉNÉRÉE
# ------------------------------------------------------------------------------
/docs/api/
/phpdoc/

# ------------------------------------------------------------------------------
# TEMPORAIRES
# ------------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
